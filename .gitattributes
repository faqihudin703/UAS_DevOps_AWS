# Force LF line endings for all text files
* text=auto eol=lf

# Explicitly LF
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sql   text eol=lf
Dockerfile text eol=lf

# Binary — no conversion
*.png   binary
*.jpg   binary
*.ico   binary
*.woff2 binary